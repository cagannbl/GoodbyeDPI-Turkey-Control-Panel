<Window x:Class="GoodbyeDPILauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GoodbyeDPI - Türkiye Kontrol Paneli"
        Width="840" Height="640"
        WindowStartupLocation="CenterScreen"
        Background="#18181C" Foreground="#F0F0F0"
        WindowStyle="None" AllowsTransparency="True"
        FontFamily="Segoe UI">
    <Window.Resources>
        <!-- ComboBox ToggleButton Template -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="24" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" />
                <Path x:Name="Arrow" Grid.Column="1" Fill="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0 Z" />
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#32323D" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="Border" Property="Background" Value="#1E1E24" />
                    <Setter TargetName="Border" Property="BorderBrush" Value="#2A2A32" />
                    <Setter TargetName="Arrow" Property="Fill" Value="#707070" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="true"/>
            <Setter Property="Background" Value="#282830"/>
            <Setter Property="BorderBrush" Value="#3D3D48"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="6,4,6,4"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" 
                                           Template="{StaticResource ComboBoxToggleButton}" 
                                           Focusable="false"
                                           Background="{TemplateBinding Background}"
                                           BorderBrush="{TemplateBinding BorderBrush}"
                                           Foreground="{TemplateBinding Foreground}"
                                           IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" 
                                           ClickMode="Press"/>
                            <ContentPresenter Name="ContentSite" 
                                               Content="{TemplateBinding SelectionBoxItem}"
                                               ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                               ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                               Margin="8,3,28,3"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               TextElement.Foreground="{TemplateBinding Foreground}" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Name="DropDownBorder" Background="#202026" BorderThickness="1" BorderBrush="#3D3D48" CornerRadius="4" Margin="0,2,0,0"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#707070" />
                                <Setter Property="Background" Value="#1E1E24" />
                                <Setter Property="BorderBrush" Value="#2A2A32" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="Foreground" Value="#F0F0F0"/>
            <Setter Property="Padding" Value="8,4,8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Border" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="3" Margin="0,1,0,1" SnapsToDevicePixels="true">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#00ADB5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#00ADB5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#00ADB5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#101014" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#2D2D37" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Height" Value="28" />
        </Style>

        <!-- Card Styles -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#202026" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#2D2D34" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="15" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="CardHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#00ADB5" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- Navigation Button Style -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#F0F0F0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="15,0,0,0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="5" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Styled Action Button Style -->
        <Style x:Key="StyledButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- --- SIDEBAR (Column 0) --- -->
        <Border Grid.Column="0" Background="#121216" BorderThickness="0,0,1,0" BorderBrush="#2D2D34">
            <StackPanel Margin="15,20,15,20">
                <!-- Logo -->
                <TextBlock Text="GoodbyeDPI" FontSize="22" FontWeight="Bold" Foreground="#00ADB5" HorizontalAlignment="Left" />
                <TextBlock x:Name="lblSub" Text="Türkiye Kontrol Paneli v3.0" FontSize="10" Foreground="#A0A0A0" Margin="0,2,0,25" />

                <!-- LED Status Card -->
                <Border Background="#202026" BorderThickness="1" BorderBrush="#2D2D34" CornerRadius="6" Padding="10,8,10,8" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="statusLed" Width="12" Height="12" Margin="2,0,8,0" VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <SolidColorBrush x:Name="ledBrushColor" Color="#E74C3C" />
                            </Ellipse.Fill>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0.3" To="1.0" Duration="0:0:1.2"
                                                             AutoReverse="True" RepeatBehavior="Forever" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock x:Name="txtStatusLedInfo" Text="Bypass Pasif" FontSize="11" FontWeight="Bold" Foreground="#F0F0F0" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Navigation Buttons -->
                <Button x:Name="btnDashboardNav" Style="{StaticResource NavButtonStyle}" Content="Kontrol Paneli" Background="#00ADB5" Foreground="White" MouseEnter="NavButton_MouseEnter" MouseLeave="NavButton_MouseLeave" Click="BtnDashboardNav_Click" />
                <Button x:Name="btnNetworkNav" Style="{StaticResource NavButtonStyle}" Content="Ağ ve DNS Ayarları" MouseEnter="NavButton_MouseEnter" MouseLeave="NavButton_MouseLeave" Click="BtnNetworkNav_Click" />
                <Button x:Name="btnBlacklistNav" Style="{StaticResource NavButtonStyle}" Content="Filtre Kara Listesi" MouseEnter="NavButton_MouseEnter" MouseLeave="NavButton_MouseLeave" Click="BtnBlacklistNav_Click" />
            </StackPanel>
        </Border>

        <!-- --- MAIN VIEW AREA (Column 1) --- -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- TitleBar Header (Window Controls) -->
            <Grid Grid.Row="0" Background="#18181C" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnMin" Content="—" Width="45" Height="35" Background="Transparent" Foreground="#F0F0F0" BorderThickness="0" Cursor="Hand" Click="BtnMin_Click" MouseEnter="BtnMin_MouseEnter" MouseLeave="BtnMin_MouseLeave">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="btnClose" Content="✕" Width="45" Height="35" Background="Transparent" Foreground="#F0F0F0" BorderThickness="0" Cursor="Hand" Click="BtnClose_Click" MouseEnter="BtnClose_MouseEnter" MouseLeave="BtnClose_MouseLeave">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Navigation Frame Panels -->
            <Grid Grid.Row="1">
                <!-- 1. panelDashboard -->
                <Grid x:Name="panelDashboard" Margin="15,0,15,15" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- LEFT SIDE: CONTROL ACTIONS -->
                    <StackPanel Grid.Column="0">
                        <!-- Card 1: Configuration -->
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Bağlantı Ayarları" Style="{StaticResource CardHeaderStyle}" />
                                <TextBlock Text="Bypass Yöntemi (Preset):" Foreground="#F0F0F0" Margin="0,0,0,4" FontSize="12" />
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="cmbPreset" Grid.Column="0" SelectionChanged="CmbPreset_SelectionChanged" />
                                    <Button x:Name="btnNewPreset" Grid.Column="1" Style="{StaticResource StyledButtonStyle}" Content="Yeni Ekle" Background="#00ADB5" Margin="8,0,0,10" Height="28" FontSize="12" Click="BtnNewPreset_Click" MouseEnter="StyledButton_MouseEnter" MouseLeave="StyledButton_MouseLeave" />
                                </Grid>

                                <!-- Custom Preset Card (Hidden by default) -->
                                <Border x:Name="borderCustomPresetCard" Background="#121216" BorderBrush="#2D2D34" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,10" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="Yeni Profil Adı:" Foreground="#F0F0F0" FontSize="11" />
                                        <TextBox x:Name="txtNewPresetName" Text="Özel Profil 1" Height="24" />
                                        
                                        <TextBlock Text="Parametreler (örn. -5 --set-ttl 4):" Foreground="#F0F0F0" FontSize="11" />
                                        <TextBox x:Name="txtNewPresetArgs" Text="-5 --set-ttl 4" Height="24" />

                                        <Grid Margin="0,5,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="btnSaveNewPreset" Grid.Column="0" Style="{StaticResource StyledButtonStyle}" Content="Kaydet" Background="#00ADB5" Height="24" FontSize="11" Click="BtnSaveNewPreset_Click" MouseEnter="StyledButton_MouseEnter" MouseLeave="StyledButton_MouseLeave" />
                                            <Button x:Name="btnCancelNewPreset" Grid.Column="1" Style="{StaticResource StyledButtonStyle}" Content="İptal" Background="#3C3C41" Height="24" FontSize="11" Margin="5,0,0,0" Click="BtnCancelNewPreset_Click" MouseEnter="StyledButton_MouseEnter" MouseLeave="StyledButton_MouseLeave" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="DNS Yönlendirme Modu:" Foreground="#F0F0F0" Margin="0,0,0,4" FontSize="12" />
                                <ComboBox x:Name="cmbDns" SelectionChanged="CmbDns_SelectionChanged">
                                    <ComboBoxItem Content="Yandex DNS (Bypass Port 1253) [Önerilen]" />
                                    <ComboBoxItem Content="Sistem DNS Ayarını Koru" />
                                    <ComboBoxItem Content="Özel DNS Tanımla..." />
                                </ComboBox>

                                <TextBlock x:Name="lblCustomDns" Text="Özel DNS:" Foreground="#F0F0F0" Margin="0,0,0,4" FontSize="12" Visibility="Collapsed" />
                                <TextBox x:Name="txtCustomDns" Text="1.1.1.1:53" Visibility="Collapsed" />
                            </StackPanel>
                        </Border>

                        <!-- Card 2: Actions -->
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Bypass İşlemleri" Style="{StaticResource CardHeaderStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="btnToggleBypass" Grid.Column="0" Style="{StaticResource StyledButtonStyle}" Content="Bypass'ı Başlat" Background="#00ADB5" Height="40" FontSize="14" Click="BtnToggleBypass_Click" MouseEnter="StyledButton_MouseEnter" MouseLeave="StyledButton_MouseLeave" />
                                    <Button x:Name="btnAutoTune" Grid.Column="1" Style="{StaticResource StyledButtonStyle}" Content="Otomatik Ayarla&#x0a;(Bağlantı Analizi)" Background="#32323A" Height="40" Margin="10,0,0,0" FontSize="11" Click="BtnAutoTune_Click" MouseEnter="StyledButton_MouseEnter" MouseLeave="StyledButton_MouseLeave" />
                                </Grid>

                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="lblProcessStatus" Grid.Column="0" Text="Uygulama: Pasif 🔴" Foreground="#E74C3C" FontSize="12" FontWeight="Bold" />
                                    <TextBlock x:Name="lblServiceStatus" Grid.Column="1" Text="Servis: Yüklü Değil 🔘" Foreground="#A0A0A0" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Card 3: Service -->
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Windows Servis Yönetimi" Style="{StaticResource CardHeaderStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="btnInstallService" Grid.Column="0" Style="{StaticResource StyledButtonStyle}" Content="Hizmet Olarak Yükle" Background="#32323A" Height="32" FontSize="11" Click="BtnInstallService_Click" MouseEnter="StyledButton_MouseEnter" MouseLeave="StyledButton_MouseLeave" />
                                    <Button x:Name="btnRemoveService" Grid.Column="1" Style="{StaticResource StyledButtonStyle}" Content="Hizmeti Kaldır" Background="#32323A" Height="32" Margin="10,0,0,0" FontSize="11" Click="BtnRemoveService_Click" MouseEnter="StyledButton_MouseEnter" MouseLeave="StyledButton_MouseLeave" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Card 4: Local PAC / Proxy -->
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Mobil Paylaşım (Yerel Ağ Proxy &amp; PAC)" Style="{StaticResource CardHeaderStyle}" />
                                <CheckBox x:Name="chkEnableProxy" Content="Proxy ve PAC Sunucusunu Aç" Foreground="#F0F0F0" Margin="0,0,0,8" FontWeight="Bold" Checked="ChkEnableProxy_CheckedChanged" Unchecked="ChkEnableProxy_CheckedChanged" />
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="lblProxyInfo" Grid.Column="0" Text="Proxy kapalı. Mobil paylaşım pasif." Foreground="#A0A0A0" TextWrapping="Wrap" FontSize="11" />
                                    <Image x:Name="imgQrCode" Grid.Column="1" Width="65" Height="65" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5,0,0,0" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- RIGHT SIDE: LOG CONSOLE -->
                    <Grid Grid.Column="1" Margin="10,10,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0">
                            <TextBlock Text="Sistem Log Kayıtları" Foreground="#F0F0F0" FontWeight="Bold" VerticalAlignment="Center" />
                            <Button x:Name="btnClearLogs" Style="{StaticResource StyledButtonStyle}" Content="Temizle" Background="#32323A" Width="65" Height="24" FontSize="11" HorizontalAlignment="Right" Click="BtnClearLogs_Click" MouseEnter="StyledButton_MouseEnter" MouseLeave="StyledButton_MouseLeave" />
                        </Grid>
                        
                        <TextBox x:Name="txtLog" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#101014" Foreground="#8EE3EB" BorderBrush="#2D2D34" FontFamily="Consolas" FontSize="11" Margin="0,5,0,0" Padding="8" />
                    </Grid>
                </Grid>

                <!-- 2. panelNetwork -->
                <Grid x:Name="panelNetwork" Margin="15,0,15,15" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- LEFT COLUMN -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <!-- Card: System Network DNS Changer -->
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Sistem Ağ Kartı DNS Değiştirici" Style="{StaticResource CardHeaderStyle}" />
                                <TextBlock Text="Seçtiğiniz DNS profilini doğrudan aktif internet adaptörlerinize uygular. Windows ayarlarına gitmeye gerek kalmaz. IPv4 ve IPv6'yı aynı anda yapılandırır." Foreground="#A0A0A0" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,10" />
                                
                                <ComboBox x:Name="cmbSysDns" SelectionChanged="CmbSysDns_SelectionChanged">
                                    <ComboBoxItem Content="Yandex DNS (77.88.8.8, 77.88.8.1 | IPv6 aktif)" />
                                    <ComboBoxItem Content="Cloudflare DNS (1.1.1.1, 1.0.0.1 | IPv6 aktif)" />
                                    <ComboBoxItem Content="Google DNS (8.8.8.8, 8.8.4.4 | IPv6 aktif)" />
                                    <ComboBoxItem Content="Otomatik DNS (DHCP'ye Döndür)" />
                                    <ComboBoxItem Content="Özel DNS Adresi gir..." />
                                </ComboBox>

                                <TextBlock x:Name="lblCustomSysDns" Text="Virgülle ayırın (Örn: 94.140.14.14, 94.140.15.15):" Foreground="#F0F0F0" Margin="0,0,0,4" FontSize="11" Visibility="Collapsed" />
                                <TextBox x:Name="txtCustomSysDns" Text="94.140.14.14, 94.140.15.15" Visibility="Collapsed" />

                                <Button x:Name="btnApplySysDns" Style="{StaticResource StyledButtonStyle}" Content="Sistem DNS Ayarını Güncelle" Background="#00ADB5" Height="35" FontSize="12" Click="BtnApplySysDns_Click" MouseEnter="StyledButton_MouseEnter" MouseLeave="StyledButton_MouseLeave" />
                            </StackPanel>
                        </Border>

                        <!-- Card: System Automation -->
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Sistem Otomasyonu &amp; Bağlantı Onarıcı" Style="{StaticResource CardHeaderStyle}" />
                                <TextBlock Foreground="#A0A0A0" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,10">
                                    Bağlantı kopukluklarında, 'WinDivert driver busy' hatalarında veya DNS kilitlenmelerinde bu onarımı çalıştırın.&#x0a;
                                    • SOCKS Port 8085'i meşgul eden diğer süreçler kapatılır.&#x0a;
                                    • Kilitli zombi süreçler ve driver handle'ları temizlenir.&#x0a;
                                    • DNS Önbelleği temizlenir ve Winsock soketleri sıfırlanır.
                                </TextBlock>
                                
                                <CheckBox x:Name="chkStartup" Content="Windows Açıldığında Otomatik Başlat (Sistem Tepsisi)" Foreground="#F0F0F0" Margin="0,0,0,10" Checked="ChkStartup_Checked" Unchecked="ChkStartup_Unchecked" />
                                
                                <Button x:Name="btnTroubleshoot" Style="{StaticResource StyledButtonStyle}" Content="Bağlantıyı ve Sürücü Kilitlerini Onar" Background="#E74C3C" Height="35" FontSize="12" Click="BtnTroubleshoot_Click" MouseEnter="StyledButton_MouseEnter" MouseLeave="StyledButton_MouseLeave" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- RIGHT COLUMN -->
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Bağlantı Durumu &amp; Erişim Testi" Style="{StaticResource CardHeaderStyle}" />
                                <Button x:Name="btnTestConnection" Style="{StaticResource StyledButtonStyle}" Content="Erişilebilirlik Testini Başlat" Background="#32323A" Height="40" FontSize="13" Click="BtnTestConnection_Click" MouseEnter="StyledButton_MouseEnter" MouseLeave="StyledButton_MouseLeave" />
                                <TextBlock x:Name="lblDiagStatus" Text="Durum: Test edilmedi.&#x0a;&#x0a;Discord ve YouTube servislerine şifreli bağlantı (TLS Handshake) kurularak, servis sağlayıcının paketi kesip kesmediği ölçümlenir. Test sonucunda bypass'ın başarısı doğrulanabilir." Foreground="#F0F0F0" TextWrapping="Wrap" FontSize="12" Margin="0,15,0,0" FontFamily="Consolas" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- 3. panelBlacklist -->
                <Grid x:Name="panelBlacklist" Margin="15,0,15,15" Visibility="Collapsed">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Filtre Kara Listesi" Style="{StaticResource CardHeaderStyle}" />
                            <CheckBox x:Name="chkUseBlacklist" Content="Sadece Kara Listedeki Siteleri İşle (Blacklist Filtre Modu)" Foreground="#F0F0F0" FontWeight="Bold" Margin="0,0,0,8" IsChecked="True" />
                            <TextBlock Foreground="#A0A0A0" TextWrapping="Wrap" FontSize="11" Margin="0,0,0,10">
                                Aşağıdaki kutuya, paket manipülasyonunun sadece hangi sitelerde geçerli olmasını istiyorsanız onları ekleyin (Her satıra bir site, örn: discord.com).&#x0a;
                                Bu kutu boşsa veya seçeneği kapatırsanız GoodbyeDPI tüm bağlantıları genel olarak filtreler (önerilen budur).
                            </TextBlock>
                            <TextBox x:Name="txtBlacklist" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="#101014" Foreground="White" BorderBrush="#2D2D34" FontFamily="Consolas" FontSize="12" Height="280" Margin="0,0,0,12" Padding="8" />
                            <Button x:Name="btnSaveBlacklist" Style="{StaticResource StyledButtonStyle}" Content="Kara Listeyi Kaydet ve Güncelle" Background="#00ADB5" Height="40" FontSize="13" Click="BtnSaveBlacklist_Click" MouseEnter="StyledButton_MouseEnter" MouseLeave="StyledButton_MouseLeave" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
