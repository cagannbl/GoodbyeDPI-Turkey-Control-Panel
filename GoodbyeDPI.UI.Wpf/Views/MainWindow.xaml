<Window x:Class="GoodbyeDPI.UI.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:GoodbyeDPI.UI.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="GoodbyeDPI - Türkiye Kontrol Paneli" 
        Height="640" Width="840"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- LED Color Converter Triggers -->
        <Style x:Key="LedStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="#E74C3C" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBypassActive}" Value="True">
                    <Setter Property="Fill" Value="#2ECC71" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Sidebar Navigation Buttons Style -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0,0,0"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- GPU-accelerated breathing animation -->
                    <DoubleAnimation Storyboard.TargetName="LedEllipse"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.3" To="1.0" Duration="0:0:1.2"
                                     AutoReverse="True" RepeatBehavior="Forever" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="10" Background="{StaticResource BackgroundBrush}" BorderThickness="1" BorderBrush="{StaticResource CardBorderBrush}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ================== SIDEBAR (Column 0) ================== -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderThickness="0,0,1,0" BorderBrush="{StaticResource CardBorderBrush}" CornerRadius="10,0,0,10">
                <StackPanel Margin="15,20,15,20">
                    <!-- Logo Header -->
                    <TextBlock Text="GoodbyeDPI" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="Türkiye Kurumsal v4.0" FontSize="10" Foreground="{StaticResource SubTextBrush}" Margin="0,2,0,25" />

                    <!-- Status Display Led -->
                    <Border Background="{StaticResource CardBrush}" BorderThickness="1" BorderBrush="{StaticResource CardBorderBrush}" CornerRadius="6" Padding="10,8,10,8" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Key="statusLed" x:Name="LedEllipse" Width="12" Height="12" Margin="2,0,8,0" VerticalAlignment="Center" Style="{StaticResource LedStyle}" />
                            <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Navigation Items -->
                    <Button Content="Kontrol Paneli" Style="{StaticResource NavButtonStyle}" Background="{StaticResource AccentBrush}" Foreground="White" Tag="Dashboard" Name="btnDashboard"/>
                    <Button Content="Ağ ve DNS Ayarları" Style="{StaticResource NavButtonStyle}" Tag="Network" Name="btnNetwork"/>
                    <Button Content="Filtre Kara Listesi" Style="{StaticResource NavButtonStyle}" Tag="Blacklist" Name="btnBlacklist"/>
                </StackPanel>
            </Border>

            <!-- ================== MAIN PANELS CONTAINER (Column 1) ================== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Window Control Titlebar -->
                <Grid Grid.Row="0" Background="Transparent" Name="TitleBar" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="—" Width="45" Height="35" Background="Transparent" Foreground="{StaticResource TextBrush}" BorderThickness="0" Cursor="Hand" Click="btnMinimize_Click"/>
                        <Button Content="✕" Width="45" Height="35" Background="Transparent" Foreground="{StaticResource TextBrush}" BorderThickness="0" Cursor="Hand" Click="btnClose_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Views -->
                <Grid Grid.Row="1" Margin="15,0,15,15">
                    
                    <!-- 1. DASHBOARD PANEL -->
                    <Grid x:Name="panelDashboard" Visibility="Visible">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="380" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Stack: Action Controls -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Top">
                            <!-- Preset selection Card -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Bağlantı Ayarları" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10" FontSize="13"/>
                                    <TextBlock Text="Bypass Yöntemi (Preset):" Margin="0,0,0,4" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}" DisplayMemberPath="Name" Height="28" Margin="0,0,0,10" Background="#282830" Foreground="White" BorderBrush="#3D3D48"/>
                                    
                                    <TextBlock Text="DNS Yönlendirme Modu:" Margin="0,0,0,4" FontSize="12"/>
                                    <ComboBox SelectedIndex="{Binding SelectedDnsModeIndex}" Height="28" Margin="0,0,0,10" Background="#282830" Foreground="White" BorderBrush="#3D3D48">
                                        <ComboBoxItem Content="Yandex DNS (Bypass Port 1253) [Önerilen]"/>
                                        <ComboBoxItem Content="Sistem DNS Ayarını Koru"/>
                                        <ComboBoxItem Content="Özel DNS Tanımla..."/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <!-- Actions Card -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Bypass İşlemleri" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10" FontSize="13"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Bypass'ı Başlat" Command="{Binding ToggleBypassCommand}" Height="40" Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                                        <Button Grid.Column="1" Content="Otomatik Ayarla" Command="{Binding AutoTuneCommand}" Height="40" Margin="10,0,0,0" Background="#32323A" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                                    </Grid>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding ProcessStatus}" FontSize="12" FontWeight="Bold" />
                                        <TextBlock Grid.Column="1" Text="{Binding ServiceStatus}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{StaticResource SubTextBrush}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Services Card -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Windows Servis Yönetimi" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10" FontSize="13"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Hizmet Olarak Yükle" Height="32" Background="#32323A" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                        <Button Grid.Column="1" Content="Hizmeti Kaldır" Height="32" Margin="10,0,0,0" Background="#32323A" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Right Panel: Log console -->
                        <Grid Grid.Column="1" Margin="15,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Sistem Log Kayıtları" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Text="{Binding LogContent}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#101014" Foreground="#8EE3EB" BorderThickness="1" BorderBrush="{StaticResource CardBorderBrush}" FontFamily="Consolas" Padding="8"/>
                        </Grid>
                    </Grid>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
